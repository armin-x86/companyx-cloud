# Local Terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform crash logs
crash.log
crash.*.log

# Terraform variable files, often containing sensitive values
*.tfvars
*.tfvars.json

# Terraform override files used for local overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform transient lock info
.terraform.tfstate.lock.info

# Terraform CLI config files
.terraformrc
terraform.rc

# Include plan files if needed
# *tfplan*

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test binaries and coverage output
*.test
*.out

# Build and cache directories
bin/
.cache/

# Virtual environments
.venv

# Secret YAML files
*-secrets.yaml
*-secrets.yml

# OS / editor files
.DS_Store
.idea/
